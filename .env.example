DISCORD_TOKEN=your-discord-bot-token
PREFIX=!

# Optional: improves Spotify support, especially playlists/albums with many tracks.
# Create an app at https://developer.spotify.com/dashboard and copy these values.
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# Optional: required for private/restricted Spotify playlists.
# Generate it with the playlist-read-private scope using your Spotify app.
SPOTIFY_REFRESH_TOKEN=your-spotify-user-refresh-token

SPOTIFY_TOP_TRACKS_COUNTRY=US
