DISCORD_TOKEN=your-discord-bot-token
PREFIX=!
ADMIN_USER_IDS=comma-separated-list-of-admin-user-ids
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REFRESH_TOKEN=your-spotify-user-refresh-token
SPOTIFY_TOP_TRACKS_COUNTRY=US
YTDLP_COOKIES_PATH=/app/data/youtube-cookies.txt
YTDLP_COOKIES_BASE64=
YTDLP_COOKIES_CONTENT=
YTDLP_COOKIES_INLINE_PATH=/tmp/youtube-cookies.txt
YTDLP_EXTRACTOR_ARGS=youtube:player_client=android_vr,web_safari
